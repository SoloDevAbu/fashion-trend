# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/fashion_trend_mvp

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Storage
STORAGE_PATH=./storage/images

# Scraping
SCRAPE_HEADLESS=true
SCRAPE_TIMEOUT_MS=30000

# Job Schedules (cron syntax)
SCRAPE_CRON=0 2 * * *
ANALYZE_CRON=0 4 * * *
TREND_CRON=0 6 * * *
GENERATE_CRON=0 8 * * *